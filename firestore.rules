rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function isValidId(id) {
      return id is string && id.size() > 0 && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isValidPromptConfig(data) {
      return data.keys().hasAll(['id', 'userId', 'name', 'productType', 'prompt', 'timestamp']) &&
             data.id is string && data.id.size() <= 128 &&
             data.userId is string && data.userId == request.auth.uid &&
             data.name is string && data.name.size() <= 200 &&
             data.productType is string && data.productType.size() <= 100 &&
             data.prompt is string && data.prompt.size() <= 10000 &&
             data.timestamp is number &&
             ( !('designStyle' in data) || (data.designStyle is string && data.designStyle.size() <= 100) ) &&
             ( !('primaryColor' in data) || (data.primaryColor is string && data.primaryColor.size() <= 50) ) &&
             ( !('fontStyle' in data) || (data.fontStyle is string && data.fontStyle.size() <= 100) ) &&
             ( !('categories' in data) || (data.categories is list && data.categories.size() <= 50 && (data.categories.size() == 0 || data.categories[0] is string)) ) &&
             ( !('isFavorite' in data) || (data.isFavorite is bool) ) &&
             ( !('generatedImage' in data) || (data.generatedImage is string && data.generatedImage.size() <= 1000000) ) &&
             ( !('logoImage' in data) || (data.logoImage is string && data.logoImage.size() <= 1000000) );
    }

    match /users/{userId} {
      // Basic profile read if we need it later, but not strictly needed for this.
      allow read: if isSignedIn() && request.auth.uid == userId;
      
      match /configs/{configId} {
        allow read: if isSignedIn() && request.auth.uid == userId;
        
        allow create: if isSignedIn() &&
                         request.auth.uid == userId &&
                         isValidId(configId) &&
                         isValidPromptConfig(incoming());
                         
        allow update: if isSignedIn() &&
                         request.auth.uid == userId &&
                         isValidId(configId) &&
                         isValidPromptConfig(incoming()) &&
                         incoming().id == existing().id &&
                         incoming().userId == existing().userId;
                         
        allow delete: if isSignedIn() && request.auth.uid == userId;
      }
    }
  }
}
